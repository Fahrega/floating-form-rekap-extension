{
  "manifest_version": 3,
  "name": "Floating Form Rekap",
  "version": "1.1",
  "description": "Formulir mengambang untuk merekap data pesanan ke Spreadsheet.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "action": {
    "default_title": "Buka/Tutup Form Rekap"
  },
  "background": {
    "service_worker": "background_script.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["Content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
